---
import BaseLayout from "./BaseLayout.astro";
import RepoTree from "~/components/RepoTree.astro";
import ArticleTOC from "~/components/ArticleTOC.astro";
import type { TreeNode, TocItem } from "~/lib/types";

interface Props {
  title: string;
  tree: TreeNode[];
  repoSlug: string;
  currentPath: string[];
  toc: TocItem[];
}
const { title, tree, repoSlug, currentPath, toc } = Astro.props;
---
<BaseLayout title={title}>
  <div class="max-w-page mx-auto grid grid-cols-[240px_1fr_220px] gap-9 px-6 py-10">
    <aside class="border-r border-border pr-4 self-start sticky top-16 max-h-[calc(100vh-5rem)] overflow-y-auto" data-repo-tree>
      <RepoTree nodes={tree} repoSlug={repoSlug} currentPath={currentPath} />
    </aside>
    <main class="max-w-prose">
      <slot />
    </main>
    <aside class="border-l border-border pl-4">
      <ArticleTOC items={toc} />
    </aside>
  </div>
  <script>
    // 长目录时把当前文章自动滚到侧栏视口中央
    requestAnimationFrame(() => {
      const aside = document.querySelector("[data-repo-tree]");
      const cur = aside?.querySelector<HTMLAnchorElement>('a[data-current="true"]');
      if (cur && aside) {
        const r = cur.getBoundingClientRect();
        const a = aside.getBoundingClientRect();
        if (r.top < a.top || r.bottom > a.bottom) {
          cur.scrollIntoView({ block: "center" });
        }
      }
    });
  </script>
</BaseLayout>
