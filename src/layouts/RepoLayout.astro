---
import BaseLayout from "./BaseLayout.astro";
import type { TreeNode } from "~/lib/types";
import RepoTree from "~/components/RepoTree.astro";
interface Props { title: string; tree: TreeNode[]; repoSlug: string; }
const { title, tree, repoSlug } = Astro.props;
---
<BaseLayout title={title}>
  <div class="max-w-page mx-auto grid grid-cols-[240px_1fr] gap-9 px-6 py-10">
    <aside class="border-r border-border pr-4 self-start sticky top-16 max-h-[calc(100vh-5rem)] overflow-y-auto" data-repo-tree>
      <RepoTree nodes={tree} repoSlug={repoSlug} />
    </aside>
    <main><slot /></main>
  </div>
</BaseLayout>
