---
import type { TocItem } from "~/lib/types";
interface Props { items: TocItem[]; }
const { items } = Astro.props;
---
<nav class="text-xs">
  <div class="text-text-faint uppercase tracking-wider text-[11px] mb-2">On this page</div>
  <ul>
    {items.map(t => {
      const indent = t.depth === 3 ? "pl-4 text-[12px]" : t.depth === 2 ? "pl-2" : "";
      const weight = t.depth === 1 ? "font-semibold text-text" : "text-text-mute";
      return (
        <li class={`py-1 ${indent} ${weight}`}>
          <a href={`#${t.id}`} class="hover:text-accent">{t.text}</a>
        </li>
      );
    })}
  </ul>
</nav>
