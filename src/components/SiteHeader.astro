---
import ThemeToggle from "~/components/ThemeToggle.astro";
---
<header class="flex items-center px-8 py-4 border-b border-border gap-6">
  <a href="/" class="font-bold text-base tracking-tight">
    Papyrus<span class="text-accent">.</span>
  </a>
  <nav class="flex gap-5 text-sm text-text-mute">
    <a href="/" class="hover:text-text">首页</a>
  </nav>
  <div class="ml-auto flex items-center gap-3">
    <button
      id="open-search"
      type="button"
      class="flex items-center gap-2 bg-bg-elev px-3 py-1.5 rounded-md text-xs text-text-faint w-64"
      aria-label="搜索（⌘K）"
    >
      <span>🔍</span>
      <span>搜索文章...</span>
      <span class="ml-auto flex gap-1">
        <kbd class="bg-bg border border-border rounded px-1.5 text-[11px]">⌘</kbd>
        <kbd class="bg-bg border border-border rounded px-1.5 text-[11px]">K</kbd>
      </span>
    </button>
    <ThemeToggle />
  </div>
</header>
