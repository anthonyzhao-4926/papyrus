---
import ThemeToggle from "~/components/ThemeToggle.astro";
import { loadConfig } from "~/lib/config";
import { isImageIcon } from "~/lib/format";

const config = await loadConfig();
const tagEntries = Object.entries(config.tags ?? {});  // [slug, { title, icon }][]

// 当前路径用来高亮（首页 / tag）
const pathname = Astro.url.pathname;
const isHome = pathname === "/" || pathname === "";
const currentTag = pathname.startsWith("/tag/") ? pathname.split("/")[2] : null;
---
<header class="flex items-center px-8 py-4 border-b border-border gap-6">
  <a href="/" class="font-bold text-base tracking-tight shrink-0">
    {config.site.name}<span class="text-accent">.</span>
  </a>
  <nav class="flex gap-1 text-sm overflow-x-auto">
    <a
      href="/"
      class={`px-3 py-1.5 rounded-md whitespace-nowrap transition ${
        isHome ? "text-text font-medium bg-bg-elev" : "text-text-mute hover:text-text hover:bg-bg-elev"
      }`}
    >
      首页
    </a>
    {tagEntries.map(([slug, tag]) => (
      <a
        href={`/tag/${slug}`}
        class={`px-3 py-1.5 rounded-md whitespace-nowrap transition ${
          currentTag === slug ? "text-text font-medium bg-bg-elev" : "text-text-mute hover:text-text hover:bg-bg-elev"
        }`}
      >
        {tag.icon && (isImageIcon(tag.icon)
          ? <img src={tag.icon} alt="" class="inline-block w-4 h-4 mr-1 -mt-0.5 object-contain" />
          : <span class="mr-1">{tag.icon}</span>)}{tag.title}
      </a>
    ))}
  </nav>
  <div class="ml-auto flex items-center gap-3 shrink-0">
    <button
      id="open-search"
      type="button"
      class="flex items-center gap-2 bg-bg-elev px-3 py-1.5 rounded-md text-xs text-text-faint w-64"
      aria-label="搜索（⌘K）"
    >
      <span>🔍</span>
      <span>搜索文章...</span>
      <span class="ml-auto flex gap-1">
        <kbd class="bg-bg border border-border rounded px-1.5 text-[11px]">⌘</kbd>
        <kbd class="bg-bg border border-border rounded px-1.5 text-[11px]">K</kbd>
      </span>
    </button>
    <ThemeToggle />
  </div>
</header>
