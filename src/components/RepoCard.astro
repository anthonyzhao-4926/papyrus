---
import { formatAgo } from "~/lib/format";
interface Props {
  slug: string;
  title: string;
  description: string;
  icon: string;
  articleCount: number;
  latestDate: string;
}
const { slug, title, description, icon, articleCount, latestDate } = Astro.props;

// 统一蓝色系：6 套蓝调渐变，按 slug 稳定取一套（保留细微深浅变化）
const palettes = [
  { grad: "from-blue-500 to-blue-700",   ring: "ring-blue-500/20" },
  { grad: "from-sky-500 to-blue-600",    ring: "ring-sky-500/20" },
  { grad: "from-blue-400 to-blue-600",   ring: "ring-blue-400/20" },
  { grad: "from-blue-600 to-blue-800",   ring: "ring-blue-600/20" },
  { grad: "from-sky-400 to-blue-600",    ring: "ring-sky-400/20" },
  { grad: "from-blue-500 to-sky-700",    ring: "ring-blue-500/20" },
];
const colorIdx = slug.split("").reduce((a, c) => a + c.charCodeAt(0), 0) % palettes.length;
const palette = palettes[colorIdx];
---
<a
  href={`/${slug}`}
  class={`group relative flex flex-col overflow-hidden border border-border rounded-2xl bg-bg transition-all duration-200 hover:-translate-y-[2px] hover:shadow-[0_24px_48px_-20px_rgba(15,23,42,.28)] hover:border-transparent hover:ring-2 ${palette.ring}`}
>
  <div class={`h-[78px] bg-gradient-to-br ${palette.grad} relative overflow-hidden`}>
    <div class="absolute -right-6 -top-6 w-24 h-24 rounded-full bg-white/10"></div>
    <div class="absolute right-8 top-10 w-12 h-12 rounded-full bg-white/10"></div>
    <div class="absolute left-5 bottom-3 w-12 h-12 rounded-[14px] bg-white/95 dark:bg-white/90 backdrop-blur flex items-center justify-center text-2xl shadow-lg">
      {icon}
    </div>
  </div>
  <div class="p-[22px] pt-[18px] flex-1 flex flex-col">
    <h4 class="text-[17px] font-bold tracking-[-0.01em] mb-[6px] text-text">{title}</h4>
    <p class="text-[13px] text-text-mute leading-[1.6] mb-[16px] flex-1">{description}</p>
    <div class="flex items-center justify-between text-[12px] text-text-faint">
      <span class="font-medium text-text-mute">{articleCount} 篇</span>
      <span>{formatAgo(latestDate)}</span>
    </div>
  </div>
</a>
